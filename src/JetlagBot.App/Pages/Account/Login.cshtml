@page
@model JetlagBot.App.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Logg inn";
}
@if (!Model.DiscordConfigured)
{
    <h1>Innlogging er utilgjengelig</h1>
    <div class="alert alert-warning">
        Discord-innlogging er ikke konfigurert. Angi <code>Discord:ClientId</code> og
        <code>Discord:ClientSecret</code> for å aktivere innlogging.
    </div>
}
else
{
    <p>Videresender til Discord for innlogging ...</p>
}
