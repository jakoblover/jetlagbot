@page
@{
    ViewData["Title"] = "Ingen tilgang";
}
<h1 class="text-danger">Ingen tilgang</h1>
<p>Discord-kontoen din står ikke på JetlagBots administrator-tillatelsesliste. Hvis du mener dette er en feil, be en eksisterende administrator om å legge til din Discord bruker-ID.</p>
<form method="post" asp-page="/Account/Logout">
    <button type="submit" class="btn btn-secondary">Logg ut</button>
</form>
