@page
@model JetlagBot.App.Pages.Admin.AdminsModel
@{
    ViewData["Title"] = "Administrasjon - Tillatelsesliste";
}

<h1>Administrator-tillatelsesliste</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

<p class="text-muted">
    Brukere på denne tillatelseslisten kan logge inn i administrasjonspanelet med Discord-kontoen sin.
</p>

<h2>Forhåndsdefinerte administratorer (fra konfigurasjon)</h2>
@if (Model.BootstrapAdminIds.Count == 0)
{
    <p class="text-muted">Ingen konfigurert.</p>
}
else
{
    <ul>
        @foreach (var id in Model.BootstrapAdminIds)
        {
            <li>@id</li>
        }
    </ul>
    <p class="text-muted">Disse defineres via innstillingen <code>Admin:DiscordUserIds</code> og kan ikke fjernes her.</p>
}

<h2>Administratorer i databasen</h2>
@if (Model.Admins.Count == 0)
{
    <p class="text-muted">Ingen administratorer i databasen ennå.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Discord bruker-ID</th>
                <th>Visningsnavn</th>
                <th>Lagt til (UTC)</th>
                <th>Lagt til av</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var admin in Model.Admins)
        {
            <tr>
                <td>@admin.DiscordUserId</td>
                <td>@admin.DisplayName</td>
                <td>@admin.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@admin.AddedByDiscordUserId</td>
                <td>
                    <form method="post" asp-page-handler="Remove" asp-route-discordUserId="@admin.DiscordUserId">
                        <button type="submit" class="btn btn-danger btn-sm">Fjern</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<hr />

<h2>Legg til administrator</h2>
<form method="post" asp-page-handler="Add" class="row g-3">
    <div class="col-md-5">
        <label class="form-label" asp-for="Input.DiscordUserId"></label>
        <input class="form-control" asp-for="Input.DiscordUserId" />
        <span asp-validation-for="Input.DiscordUserId" class="text-danger"></span>
    </div>
    <div class="col-md-5">
        <label class="form-label" asp-for="Input.DisplayName"></label>
        <input class="form-control" asp-for="Input.DisplayName" />
        <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-success">Legg til</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
