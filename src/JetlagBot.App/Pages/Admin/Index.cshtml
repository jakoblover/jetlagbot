@page
@model JetlagBot.App.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Administrasjon - Innstillinger";
}

<h1>Server-innstillinger</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

<p class="text-muted">
    Konfigurer anbefalingsreglene per server. <strong>Minimum medlemskapsalder</strong> er hvor lenge et medlem må ha
    vært i serveren før det kan anbefale. <strong>Karantenetid mellom anbefalinger</strong> er minste antall dager mellom
    anbefalinger fra samme medlem.
</p>

@if (Model.GuildSettings.Count == 0)
{
    <div class="alert alert-info">
        Det finnes ingen server-innstillinger ennå. De opprettes automatisk første gang noen forsøker å anbefale, eller du kan
        opprette en nedenfor ved hjelp av server-ID-en.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Server-ID</th>
                <th>Minimum medlemskapsalder (dager)</th>
                <th>Karantenetid mellom anbefalinger (dager)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var settings in Model.GuildSettings)
        {
            <tr>
                <form method="post" asp-page-handler="Save">
                    <td>
                        <input type="hidden" name="Input.GuildId" value="@settings.GuildId" />
                        @settings.GuildId
                    </td>
                    <td>
                        <input class="form-control" type="number" min="0" name="Input.MinimumMembershipAgeDays" value="@settings.MinimumMembershipAgeDays" />
                    </td>
                    <td>
                        <input class="form-control" type="number" min="0" name="Input.VouchCooldownDays" value="@settings.VouchCooldownDays" />
                    </td>
                    <td>
                        <button type="submit" class="btn btn-primary">Lagre</button>
                    </td>
                </form>
            </tr>
        }
        </tbody>
    </table>
}

<hr />

<h2>Legg til innstillinger for en server</h2>
<form method="post" asp-page-handler="Save" class="row g-3">
    <div class="col-md-4">
        <label class="form-label" asp-for="Input.GuildId"></label>
        <input class="form-control" asp-for="Input.GuildId" />
        <span asp-validation-for="Input.GuildId" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label class="form-label" asp-for="Input.MinimumMembershipAgeDays"></label>
        <input class="form-control" asp-for="Input.MinimumMembershipAgeDays" value="365" />
        <span asp-validation-for="Input.MinimumMembershipAgeDays" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label class="form-label" asp-for="Input.VouchCooldownDays"></label>
        <input class="form-control" asp-for="Input.VouchCooldownDays" value="30" />
        <span asp-validation-for="Input.VouchCooldownDays" class="text-danger"></span>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-success">Legg til</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
