@page
@model JetlagBot.App.Pages.Admin.VouchesModel
@{
    ViewData["Title"] = "Admin - Vouches";
}

<h1>Vouches</h1>

<p class="text-muted">Search the vouches a user has received by guild id and target user id.</p>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-5">
        <label class="form-label" asp-for="GuildId">Guild id</label>
        <input class="form-control" asp-for="GuildId" />
    </div>
    <div class="col-md-5">
        <label class="form-label" asp-for="TargetUserId">Target user id</label>
        <input class="form-control" asp-for="TargetUserId" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (Model.Searched)
{
    @if (Model.Vouches.Count == 0)
    {
        <div class="alert alert-info">No vouches found for that user in that guild.</div>
    }
    else
    {
        <p>@Model.Vouches.Count vouch(es) found.</p>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Date (UTC)</th>
                    <th>Voucher</th>
                    <th>Voucher id</th>
                    <th>Message</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var vouch in Model.Vouches)
            {
                <tr>
                    <td>@vouch.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@vouch.VoucherDisplayName</td>
                    <td>@vouch.VoucherUserId</td>
                    <td>@vouch.Message</td>
                </tr>
            }
            </tbody>
        </table>
    }
}
