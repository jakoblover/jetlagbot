@page
@model JetlagBot.App.Pages.Admin.VouchesModel
@{
    ViewData["Title"] = "Administrasjon - Anbefalinger";
}

<h1>Anbefalinger</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

<p class="text-muted">
    Skriv inn en server-ID for å se alle anbefalinger som er gitt i den serveren. Du kan eventuelt fylle inn en
    målbruker-ID for å bare vise anbefalingene én bestemt bruker har mottatt.
</p>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-5">
        <label class="form-label" asp-for="GuildId">Server-ID</label>
        <input class="form-control" asp-for="GuildId" />
    </div>
    <div class="col-md-5">
        <label class="form-label" asp-for="TargetUserId">Målbruker-ID (valgfritt)</label>
        <input class="form-control" asp-for="TargetUserId" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Søk</button>
    </div>
</form>

@if (Model.Searched)
{
    @if (Model.Vouches.Count == 0)
    {
        <div class="alert alert-info">Fant ingen anbefalinger for denne serveren.</div>
    }
    else
    {
        <p>Fant @Model.Vouches.Count anbefaling(er).</p>
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Dato (UTC)</th>
                    <th>Mottaker</th>
                    <th>Mottaker-ID</th>
                    <th>Anbefaler</th>
                    <th>Anbefaler-ID</th>
                    <th>Melding</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var vouch in Model.Vouches)
            {
                <tr>
                    <td>@vouch.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@vouch.TargetDisplayName</td>
                    <td>@vouch.TargetUserId</td>
                    <td>@vouch.VoucherDisplayName</td>
                    <td>@vouch.VoucherUserId</td>
                    <td>@vouch.Message</td>
                    <td>
                        <form method="post" asp-page-handler="Delete"
                              asp-route-id="@vouch.Id"
                              asp-route-GuildId="@Model.GuildId"
                              asp-route-TargetUserId="@Model.TargetUserId"
                              onsubmit="return confirm('Er du sikker på at du vil slette denne anbefalingen?');">
                            <button type="submit" class="btn btn-danger btn-sm">Slett</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}
