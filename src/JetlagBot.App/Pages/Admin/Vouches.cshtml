@page
@model JetlagBot.App.Pages.Admin.VouchesModel
@{
    ViewData["Title"] = "Administrasjon - Anbefalinger";
}

<h1>Anbefalinger</h1>

<p class="text-muted">Søk i anbefalingene en bruker har mottatt ved hjelp av server-ID og målbrukerens ID.</p>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-5">
        <label class="form-label" asp-for="GuildId">Server-ID</label>
        <input class="form-control" asp-for="GuildId" />
    </div>
    <div class="col-md-5">
        <label class="form-label" asp-for="TargetUserId">Målbrukerens ID</label>
        <input class="form-control" asp-for="TargetUserId" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Søk</button>
    </div>
</form>

@if (Model.Searched)
{
    @if (Model.Vouches.Count == 0)
    {
        <div class="alert alert-info">Fant ingen anbefalinger for den brukeren i den serveren.</div>
    }
    else
    {
        <p>Fant @Model.Vouches.Count anbefaling(er).</p>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Dato (UTC)</th>
                    <th>Anbefaler</th>
                    <th>Anbefalerens ID</th>
                    <th>Melding</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var vouch in Model.Vouches)
            {
                <tr>
                    <td>@vouch.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@vouch.VoucherDisplayName</td>
                    <td>@vouch.VoucherUserId</td>
                    <td>@vouch.Message</td>
                </tr>
            }
            </tbody>
        </table>
    }
}
