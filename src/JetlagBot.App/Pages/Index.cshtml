@page
@model IndexModel
@{
    ViewData["Title"] = "Hjem";
}

<div class="text-center">
    <h1 class="display-4">JetlagBot</h1>
    <p class="lead">En Discord-anbefalingsbot med et nettbasert administrasjonspanel.</p>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <a class="btn btn-primary" asp-page="/Admin/Index">Gå til administrasjonspanelet</a>
    }
    else
    {
        <a class="btn btn-primary" asp-page="/Account/Login">Logg inn med Discord</a>
    }
</div>
