# Database connection string (PostgreSQL provided externally / by Dokploy)
ConnectionStrings__Default=Host=your-db-host;Port=5432;Database=jetlagbot;Username=jetlagbot;Password=changeme

# Apply EF Core migrations on startup (true/false)
Database__MigrateOnStartup=true

# Discord bot + OAuth credentials
Discord__BotToken=your-bot-token
Discord__ClientId=your-oauth-client-id
Discord__ClientSecret=your-oauth-client-secret

# Optional: the guild the bot primarily serves (ensures settings exist on startup)
Discord__PrimaryGuildId=

# Optional: register slash commands instantly to a single guild during development
Discord__DevGuildId=

# Bootstrap admin allowlist (one Discord user id per indexed entry)
Admin__DiscordUserIds__0=your-discord-user-id
